# fly.toml dla szczypior-db-service
app = 'szczypior-db-service'
primary_region = 'fra'

[build]
  dockerfile = "infrastructure/docker/db-service.Dockerfile"

[http_service]
  internal_port = 80
  force_https = true
  auto_stop_machines = 'off'
  auto_start_machines = true
  min_machines_running = 1
  processes = ["app"]

[checks]
  [checks.health]
    type = "http"
    grace_period = "30s"
    interval = "15s"
    method = "GET"
    path = "/"
    timeout = "10s"

[[vm]]
  size = 'shared-cpu-1x'
  memory = '512mb'

[env]
  DB_SERVICE_API_KEY_HEADER = "X-API-Key"

# Sekrety ustawiane przez: ./deploy.sh
# Lub ręcznie: fly secrets set KEY=value
# 
# Wymagane sekrety:
# - DB_SERVICE_API_KEY
# - user (DB username)
# - password (DB password)
# - host (DB host)
# - port (DB port)
# - dbname (DB name)
