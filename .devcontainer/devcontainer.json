{
  "name": "Szczypior Python Dev",
  "dockerComposeFile": "docker-compose.dev.yml",
  "service": "workspace",
  "workspaceFolder": "/workspaces/Szczypior-Discord-Bot",
  "settings": {
    "python.pythonPath": "/usr/local/bin/python",
    "python.formatting.provider": "black",
    "python.linting.enabled": true,
    "python.linting.pylintEnabled": true,
    "editor.formatOnSave": true
  },
  "forwardPorts": [
    8001,
    8000,
    3000
  ],
  "runServices": [
    "db-service"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.black-formatter",
        "ms-azuretools.vscode-docker",
        "ms-python.debugpy",
        "bradlc.vscode-tailwindcss",
        "formulahendry.docker-explorer",
        "GitHub.copilot-chat",
        "tht13.python",
        "ms-vscode.vscode-typescript-next", 
        "esbenp.prettier-vscode"  
      ]
    }
  },
  "postCreateCommand": "apt-get update && apt-get install -y nodejs npm && pip install -r services/db-service/requirements.txt && pip install -r services/discord-bot-szczypior/requirements.txt && pip install -r services/web-dashboard/requirements.txt",
  "remoteUser": "root"
}