{
  "name": "Szczypior Python Dev",
  "dockerComposeFile": "docker-compose.dev.yml",
  "service": "workspace",
  "workspaceFolder": "/workspaces/Szczypior-Discord-Bot",
  "forwardPorts": [8000, 3000],
  "runServices": ["db-service"],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.black-formatter",
        "ms-azuretools.vscode-docker",
        "ms-python.debugpy",
        "bradlc.vscode-tailwindcss"
      ]
    }
  },
  "postCreateCommand": "pip install -r services/db-service/requirements.txt",
  "remoteEnv": {
    "DATABASE_URL": "${localEnv:DATABASE_URL}",
    "DISCORD_TOKEN": "${localEnv:DISCORD_TOKEN}"
  }
}
