# Przykładowy plik konfiguracyjny
# Skopiuj ten plik jako .env i uzupełnij własnymi wartościami

# Token Discord Bot (wymagany)
DISCORD_TOKEN=your_discord_token_here

# ID Serwera Discord (opcjonalnie)
GUILD_ID=your_guild_id_here

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Google Sheets Configuration (Legacy - Soon deprecated)
# ID arkusza z URL: https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# PostgreSQL Database (Supabase)
DATABASE_URL=postgresql://postgres.[project-ref]:[db-password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# Format: postgresql://postgres.[project-ref]:[db-password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Supavisor transaction pooler - port 6543 (nie używaj db.xxx.supabase.co - DNS może nie działać)
# Get from: https://app.supabase.com/project/_/settings/database → "Connection string" → "Transaction"

# Discord Channel ID (kanał do monitorowania)
MONITORED_CHANNEL_ID=your_channel_id_here